# HOI-YO AI Strategy for {{ tag }} -- Turn {{ turn_number }}
# Generated by hoi-yo Clausewitz strategy writer
# Mood: {{ mood }}

{% for strat in diplomatic_strategies %}
{{ tag }}_hoi_yo_diplo_{{ loop.index }} = {
    allowed = { original_tag = {{ tag }} }
    enable = { always = yes }
    abort = { always = no }
    ai_strategy = {
        type = {{ strat.strategy_type }}
        id = "{{ strat.target }}"
        value = {{ strat.value }}
    }
    weight = { modifier = { factor = 1000 } }
}

{% endfor %}
{% for strat in military_strategies %}
{{ tag }}_hoi_yo_mil_{{ loop.index }} = {
    allowed = { original_tag = {{ tag }} }
    enable = { always = yes }
    abort = { always = no }
    ai_strategy = {
        type = {{ strat.strategy_type }}
        id = "{{ strat.id }}"
        value = {{ strat.value | int }}
        {% if strat.execution_type %}
        execution_type = {{ strat.execution_type }}
        {% endif %}
    }
    weight = { modifier = { factor = 1000 } }
}

{% endfor %}
{% for strat in production_strategies %}
{{ tag }}_hoi_yo_prod_{{ loop.index }} = {
    allowed = { original_tag = {{ tag }} }
    enable = { always = yes }
    abort = { always = no }
    ai_strategy = {
        type = {{ strat.strategy_type }}
        {% if strat.id %}
        id = "{{ strat.id }}"
        {% endif %}
        value = {{ strat.value | int }}
    }
    weight = { modifier = { factor = 1000 } }
}

{% endfor %}

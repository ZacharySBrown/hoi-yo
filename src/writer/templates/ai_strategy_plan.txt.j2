# HOI-YO AI Strategy Plan for {{ tag }} -- Turn {{ turn_number }}
# Generated by hoi-yo Clausewitz strategy writer

{{ tag }}_hoi_yo_plan = {
    name = "{{ tag }}_hoi_yo_plan"
    allowed = { original_tag = {{ tag }} }
    enable = { always = yes }
    abort = { always = no }
    {% if research %}
    research = {
        {% for cat, mult in research.items() %}
        {{ cat }} = {{ mult }}
        {% endfor %}
    }
    {% endif %}
    {% for focus_id, weight in focus_prefs.items() %}
    focus_factors = {
        {{ focus_id }} = {{ weight }}
    }
    {% endfor %}
    weight = { modifier = { factor = 1000 } }
}
